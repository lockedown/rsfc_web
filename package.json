{
  "name": "rsfc-web",
  "version": "0.1.0",
  "description": "Raw Skills FC website - Next.js + Payload CMS v3",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation payload migrate && cross-env NODE_OPTIONS=--no-deprecation next build",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload"
  },
  "dependencies": {
    "@payloadcms/db-vercel-postgres": "3.82.1",
    "@payloadcms/next": "3.82.1",
    "@payloadcms/richtext-lexical": "3.82.1",
    "@payloadcms/storage-s3": "3.82.1",
    "@payloadcms/ui": "3.82.1",
    "cross-env": "10.1.0",
    "graphql": "^16.8.1",
    "next": "16.2.6",
    "payload": "3.82.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "0.34.4"
  },
  "devDependencies": {
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.14",
    "tsx": "4.21.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
