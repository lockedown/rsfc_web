# --- Payload ---
PAYLOAD_SECRET=replace-with-a-long-random-string
DATABASE_URI=postgres://user:password@localhost:5432/rsfc

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Cloudflare R2 (S3-compatible) ---
S3_BUCKET=rsfc-media
S3_REGION=auto
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=https://media.rawskillsfc.com

# --- Resend (transactional email) ---
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@rawskillsfc.com
CONTACT_FROM_EMAIL=no-reply@rawskillsfc.com

# --- Cloudflare Turnstile ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
